rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // データ型のバリデーション関数
    function isValidProfile(data) {
      return data.total_points is number && data.total_points >= 0
          && data.nickname is string;
    }

    // ログイン済みユーザーのみプロフィールを読み書き可能（自分のみ）
    match /profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && isValidProfile(request.resource.data);
    }
    
    // 学習ログ: 自分のものだけ読み書き可能
    match /study_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    
    // ポイント履歴: 自分のものだけ読み書き可能
    match /point_transactions/{txnId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    
    // ミッション進捗: 自分のものだけ読み書き可能
    match /user_missions/{missionId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
